{
  "name": "agent-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "reset-test": "node ../scripts/reset-test-calls.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:capabilities": "npx tsx --test src/lib/__tests__/capabilities.test.ts",
    "test:agent-context": "npx tsx --test src/lib/__tests__/agent-context.test.ts",
    "test:client-agent-config": "npx tsx --test src/lib/__tests__/build-client-agent-config.test.ts",
    "test:knowledge-summary": "npx tsx --test src/lib/__tests__/knowledge-summary.test.ts",
    "test:knowledge-retrieval": "npx tsx --test src/lib/__tests__/knowledge-retrieval.test.ts",
    "test:niche-delta": "npx tsx --test src/lib/__tests__/niche-delta.test.ts",
    "test:provisioning-guards": "npx tsx --test src/lib/__tests__/provisioning-guards.test.ts",
    "test:pm-ops": "npx tsx --test src/lib/__tests__/pm-ops.test.ts",
    "test:prompt-patcher": "npx tsx --test src/lib/__tests__/prompt-patcher.test.ts",
    "test:prompt-snapshots": "npx tsx --test src/lib/__tests__/prompt-snapshots.test.ts",
    "test:agent-context-hours": "npx tsx --test src/lib/__tests__/agent-context-hours.test.ts",
    "test:settings-truth": "npx tsx --test src/lib/__tests__/settings-runtime-truth.test.ts",
    "test:capability-truth": "npx tsx --test src/lib/__tests__/capability-truth.test.ts",
    "test:tool-registration": "npx tsx --test src/lib/__tests__/tool-registration-truth.test.ts",
    "test:prompt-version-audit": "npx tsx --test src/lib/__tests__/prompt-version-audit.test.ts",
    "test:notification-guards": "npx tsx --test src/lib/__tests__/notification-guards.test.ts",
    "test:all": "npx tsx --test src/lib/__tests__/*.test.ts",
    "test:canary": "npx tsx ../tests/canary/eval-harness.ts",
    "test:smoke": "bash scripts/smoke-test.sh",
    "db:types": "npx supabase gen types typescript --project-id qwhvblomlgeapzhnuwlb > src/lib/database.types.ts",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:ui:report": "npx playwright show-report",
    "prepare": "if [ -d .git ]; then git config core.hooksPath .githooks; fi"
  },
  "dependencies": {
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.68",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "driver.js": "^1.4.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.12.0",
    "motion": "^12.35.1",
    "next": "16.1.6",
    "ogl": "^1.0.11",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.4",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "twilio": "^5.12.2",
    "ultravox-client": "^0.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
