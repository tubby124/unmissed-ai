#!/bin/sh
# S18o: Run full build before every push (catches module-level SDK init + type errors).
# S18p: Grep guard for module-level SDK initialization patterns.
# Install: git config core.hooksPath .githooks

echo "=== Pre-push checks ==="

# ── S18p: Detect module-level SDK initialization ─────────────────────────────
echo "[1/4] Checking for module-level SDK initialization..."
MATCHES=$(grep -rn '^\(export \)\{0,1\}const .* = new Stripe\|^\(export \)\{0,1\}const .* = createClient(\|^\(export \)\{0,1\}const .* = createServiceClient(\|^\(export \)\{0,1\}const .* = createBrowserClient(' src/app/ src/lib/ 2>/dev/null || true)

if [ -n "$MATCHES" ]; then
  echo ""
  echo "BLOCKED: Module-level SDK initialization detected (S18m/S18p)."
  echo "These patterns crash during next build when env vars are unavailable:"
  echo ""
  echo "$MATCHES"
  echo ""
  echo "Fix: Move initialization inside function bodies or use lazy-init pattern."
  exit 1
fi
echo "  No module-level SDK init found."

# ── S18o: Full build check ───────────────────────────────────────────────────
echo "[2/4] Running full build (npm run build)..."
BUILD_ATTEMPTS=0
BUILD_SUCCESS=0
while [ $BUILD_ATTEMPTS -lt 3 ]; do
  BUILD_ATTEMPTS=$((BUILD_ATTEMPTS + 1))
  # Only wipe .next on first attempt — retries reuse cache to avoid Turbopack
  # race condition where .tmp optimization files are written then immediately read
  if [ $BUILD_ATTEMPTS -eq 1 ]; then
    rm -rf .next
  fi
  npm run build 2>&1
  if [ $? -eq 0 ]; then
    BUILD_SUCCESS=1
    break
  fi
  echo ""
  echo "Build attempt $BUILD_ATTEMPTS/3 failed (possible Turbopack race condition). Retrying..."
  echo ""
done

if [ $BUILD_SUCCESS -eq 0 ]; then
  echo ""
  echo "Build failed after $BUILD_ATTEMPTS attempts. Push aborted. Fix build errors and try again."
  exit 1
fi

# ── S18p: Detect module-level SDK initialization (post-build double-check) ────
echo "[3/4] Checking for module-level SDK initialization (S18p)..."
MODULE_INIT=$(grep -rn '^\(export \)\?const .* = new Stripe\|^\(export \)\?const .* = createClient()\|^\(export \)\?const .* = createServiceClient()' src/app/ src/lib/ 2>/dev/null || true)
if [ -n "$MODULE_INIT" ]; then
  echo ""
  echo "ERROR: Module-level SDK initialization detected (S18p):"
  echo "$MODULE_INIT"
  echo ""
  echo "Move these into function bodies or use lazy-init pattern."
  echo "See memory/feedback-nextjs-build-safety.md"
  exit 1
fi
echo "  No module-level SDK init found."

# ── S18b: Fire-and-forget .then() baseline check ─────────────────────────────
echo "[4/4] Checking .then() count in route handlers (S18b)..."
THEN_COUNT=$(grep -r '\.then(' src/app/api/ src/lib/ --include='*.ts' 2>/dev/null | wc -l | tr -d ' ')
THEN_BASELINE=5
if [ "$THEN_COUNT" -gt "$THEN_BASELINE" ]; then
  echo ""
  echo "ERROR: .then() count in route handlers increased ($THEN_COUNT > baseline $THEN_BASELINE)"
  echo "Convert new .then() patterns to await. See S18b."
  exit 1
fi
echo "  .then() count OK ($THEN_COUNT <= baseline $THEN_BASELINE)."

echo ""
echo "=== All pre-push checks passed ==="
